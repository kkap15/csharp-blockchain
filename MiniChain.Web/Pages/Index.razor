@page "/"                                                                                                                                                                                                                         
  @inject Services.ChainService Chain                                                                                                                                                                                 
  @implements IDisposable                                                                                                                                                                                                           
                                                                                                                                                                                                                                    
  <h1>Dashboard</h1>                                                                                                                                                                                                                
                                                                                                                                                                                                                                    
  <p>Height: <strong>@Chain.Blockchain.Height</strong></p>                                                                                                                                                                          
  <p>Tip: <strong>@Chain.Blockchain.Tip.ComputeHash()[..12]...</strong></p>                                                                                                                                                       
  <p>Valid: <strong>@Chain.Blockchain.IsValid()</strong></p>                                                                                                                                                                        
   
  <button @onclick="Mine">Mine Block</button>                                                                                                                                                                                       
                                                                                                                                                                                                                                  
  @if (Chain.Wallet is null)                                                                                                                                                                                                        
  {                                                     
      <p>No wallet loaded — go to <a href="wallet">Wallet</a> to create one.</p>
  }                                                                                                                                                                                                                                 
   
  @code {                                                                                                                                                                                                                           
      protected override void OnInitialized()           
      {                                                                                                                                                                                                                             
          Chain.OnChange += Refresh;                    
      }

      private void Mine()                                                                                                                                                                                                           
      {
          if (Chain.Wallet is null) return;                                                                                                                                                                                         
          Chain.Blockchain.MineFromMempool(Chain.Mempool, Chain.Mempool.Pending.Count, Chain.Wallet.PublicKeyHex);
          Chain.NotifyStateChanged();                                                                                                                                                                                               
      }                                                                                                                                                                                                                             
                                                                                                                                                                                                                                    
      private void Refresh() => InvokeAsync(StateHasChanged);                                                                                                                                                                       
                                                        
      public void Dispose()                                                                                                                                                                                                         
      {                                                 
          Chain.OnChange -= Refresh;
      }
  }
