@page "/"
@attribute [Authorize]

@inject ChainService Chain      
@inject WalletService Wallet
@inject AuthenticationStateProvider AuthStateProvider                                                                                                                                                                               
@using System.Security.Claims
@using MiniChain.Web.Services
@implements IDisposable                                                                                                                                                                                                           
                                                                                                                                                                                                                                    
  <h1>Dashboard</h1>                                                                                                                                                                                                                
                                                                                                                                                                                                                                    
  <p>Height: <strong>@Chain.Blockchain.Height</strong></p>                                                                                                                                                                          
  <p>Tip: <strong>@Chain.Blockchain.Tip.ComputeHash()[..12]...</strong></p>                                                                                                                                                       
  <p>Valid: <strong>@Chain.Blockchain.IsValid()</strong></p>                                                                                                                                                                        
   
  <button @onclick="Mine" disabled="@_mining">
      @(_mining ? "Mining" : "Mine Block")
  </button>                                                                                                                                                                                       
                                                                                                                                                                                                                                  
  @if (Wallet.GetWallet(_userId) is null)                                                                                                                                                                                                        
  {                                                     
      <p>No wallet loaded — go to <a href="/wallet">Wallet</a> to create one.</p>
  }                                                                                                                                                                                                                                 
   
  @code {
      private bool _mining;
      private string? _userId;
      
      protected override async Task OnInitializedAsync()
      {
          _userId = await GetUserId();
          Chain.OnChange += Refresh;                    
      }

      private async Task Mine()                                                                                                                                                                                                           
      {
          if (Wallet.GetWallet(_userId) is null) return;    
          _mining =  true;
          await Chain.MineBlockAsync(Wallet.GetWallet(_userId)!.PublicKeyHex);
          Chain.NotifyStateChanged();       
          _mining = false;
      }

      private async Task<string?> GetUserId()
      {
          var state = await AuthStateProvider.GetAuthenticationStateAsync();
          return state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;                                                                                                                                                                                         
      }
                                                                                                                                                                                                                                    
      private void Refresh() => InvokeAsync(StateHasChanged);                                                                                                                                                                       
                                                        
      public void Dispose()                                                                                                                                                                                                         
      {                                                 
          Chain.OnChange -= Refresh;
      }
  }
