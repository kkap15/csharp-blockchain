@page "/mempool"
@attribute [Authorize]

@inject ChainService Chain
@inject WalletService Wallet
@inject AuthenticationStateProvider AuthenticationStateProvider

@using System.Security.Claims
@using MiniChain.Web.Services

@implements IDisposable

<h3>Mempool</h3>

@if (!Chain.Mempool.Pending.Any())
{
    <p>No pending transactions.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>From</th>
            <th>To</th>                                                                                                                                                                                                       
            <th>Amount</th>
        </tr>                                                                                                                                                                                                                 
        </thead>                                         
        <tbody>
        @foreach (var tx in Chain.Mempool.Pending)
        {                                                                                                                                                                                                                     
            <tr>
                <td><code>@tx.From[..12]...</code></td>                                                                                                                                                                       
                <td><code>@tx.To[..Math.Min(12, tx.To.Length)]...</code></td>                                                                                                                                                 
                <td>@tx.Amount</td>
            </tr>                                                                                                                                                                                                             
        }                                            
        </tbody>                                                                                                                                                                                                                  
    </table>
}
@if (Wallet.GetWallet(_userId) is not null)
{
    <button @onclick="Mine" disabled="@_mining">
        @(_mining ? "Mining" : "Mine Block")
    </button>
}                                                                                                                                                                                                                                 
else
{                                                                                                                                                                                                                                 
    <p>Create a wallet first to mine.</p>                
}
@code {
    private bool _mining;
    private string? _userId;
    
    private async Task Mine()
    {
        if (Wallet.GetWallet(_userId) is null) return;
        _mining = true; 
        await Chain.MineBlockAsync(Wallet.GetWallet(_userId)!.PublicKeyHex);                                                                                                                                                                                    
        Chain.NotifyStateChanged();
        _mining = false;
    }

    protected override async Task OnInitializedAsync()
    {
        _userId = await GetUserId();
        Chain.OnChange += Refresh;
    }

    private async Task<string?> GetUserId()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Chain.OnChange -= Refresh;
    }
}